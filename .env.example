# Environment Variables Template
# Copia este archivo a .env.local y rellena con tus valores

# =====================================================
# AUTENTICACIÓN
# =====================================================

# Generar con: npx auth secret
# Este secret se usa para firmar JWT de NextAuth.js
# IMPORTANTE: Debe ser diferente en cada ambiente (dev, staging, prod)
NEXTAUTH_SECRET=your_generated_secret_here

# =====================================================
# BASE DE DATOS
# =====================================================

# PostgreSQL connection string
# Formato: postgres://usuario:contraseña@host:puerto/nombre_base_datos
# Ejemplo local: postgres://postgres:postgres@localhost:5432/eco-db
DATABASE_URL=postgres://user:password@localhost:5432/eco-db

# =====================================================
# OAUTH - GOOGLE (REQUIRED FOR AUTH)
# =====================================================

# Obtener en: https://console.cloud.google.com/
# 1. Crear proyecto en Google Cloud Console
# 2. Habilitar "Google+ API"
# 3. Crear "OAuth 2.0 Client ID" (Application type: Web application)
# 4. Configurar URIs autorizados:
#    - Authorized JavaScript origins: http://localhost:3000
#    - Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
# 5. Copiar Client ID y Client Secret aquí

GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# =====================================================
# OAUTH - GITHUB (OPCIONAL)
# =====================================================

# Obtener en: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
